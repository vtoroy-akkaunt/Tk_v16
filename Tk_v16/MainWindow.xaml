<Window x:Class="Tk_v16.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tk_v16"
        mc:Ignorable="d"
        Title="Применение закона Ома" Height="450" Width="800">
    <Grid Margin="100 50">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*"></ColumnDefinition>
            <ColumnDefinition Width="40*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70*"></RowDefinition>
                <RowDefinition Height="30*"></RowDefinition>
            </Grid.RowDefinitions>
            <!-- Вводы и результат -->
            <Grid Grid.Row="0">
                <!-- Забыл как делать нормально -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*"></ColumnDefinition>
                    <ColumnDefinition Width="50*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"></RowDefinition>
                    <RowDefinition Height="20"></RowDefinition>
                </Grid.RowDefinitions>
                <!-- Вводы -->
                <TextBlock x:Name="label1" Grid.Column="0" Grid.Row="0"></TextBlock>
                <TextBox x:Name="input1" Grid.Column="1" Grid.Row="0"></TextBox>
                <TextBlock x:Name="label2" Grid.Column="0" Grid.Row="1"></TextBlock>
                <TextBox x:Name="input2" Grid.Column="1" Grid.Row="1"></TextBox>
            </Grid>
            <!-- Результат -->
            <!-- Я больше по стак-панелям -->
            <TextBlock x:Name="result" FontWeight="SemiBold" Text="Сила тока =" Grid.Row="1"/>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70*"></RowDefinition>
                <RowDefinition Height="30*"></RowDefinition>
            </Grid.RowDefinitions>
            <!-- Не помню, как называется элемент, объединяющий элементы в группу с границей и
            подписью (типа "Вычисляемая величина") (в wxwidgets это назвалось static-что-то там) -->
            <StackPanel Orientation="Vertical" Grid.Row="0">
                <RadioButton Content="Сила тока" x:Name="rb_current" IsChecked="True" Checked="rb_changed"/>
                <RadioButton Content="Напряжение" x:Name="rb_voltage" Click="rb_changed"/>
                <RadioButton Content="Сопротивление" x:Name="rb_resistance" Click="rb_changed"/>
            </StackPanel>
            <Button Content="Вычислить" Grid.Row="1" Width="80" Height="20" Click="btn_calc_Click"/>
        </Grid>
    </Grid>
</Window>
